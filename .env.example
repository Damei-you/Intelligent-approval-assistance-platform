DATABASE_URL=postgresql://approval_user:L123456@localhost:5432/approval_assistant
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE=20971520
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# 请在本机系统环境变量中填写真实值，不要提交到 Git。
api-key=replace-with-your-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BATCH_SIZE=10
# 聊天模型与 Embedding 请求超时，必须明显小于问答占位的 10 分钟回收时间。
MODEL_TIMEOUT_SECONDS=60
# 风险审查聊天模型与向量模型共用上方 api-key 和百炼兼容地址。
REVIEW_MODEL=qwen-plus
# 制度侧向量召回 Top 10，经重排序后取 Top 5；合同侧仍保持向量 Top 3。
RERANK_MODEL=qwen3-rerank
RERANK_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
RERANK_TIMEOUT_SECONDS=20
POLICY_RECALL_TOP_K=10
POLICY_FINAL_TOP_K=5
