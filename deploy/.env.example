# PostgreSQL 初始化配置。生产服务器必须替换演示密码。
POSTGRES_DB=approval_assistant
POSTGRES_USER=approval_user
POSTGRES_PASSWORD=replace-with-a-strong-random-password

# 容器通过 Compose 服务名访问 PostgreSQL 和 Redis。
DATABASE_URL=postgresql://approval_user:replace-with-a-strong-random-password@postgres:5432/approval_assistant
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

UPLOAD_DIR=/app/storage/uploads
MAX_UPLOAD_SIZE=20971520
CORS_ORIGINS=https://contract.zhigu.site

# 应用代码只读取名为 api-key 的环境变量；真实值只写入服务器 deploy/.env。
api-key=replace-with-your-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BATCH_SIZE=10
MODEL_TIMEOUT_SECONDS=60
REVIEW_MODEL=qwen-plus
RERANK_MODEL=qwen3-rerank
RERANK_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
RERANK_TIMEOUT_SECONDS=20
POLICY_RECALL_TOP_K=10
POLICY_FINAL_TOP_K=5

